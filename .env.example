# Anthropic API — para análisis de IA
# Obtenela en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Puerto del servidor
PORT=3000

# Scraping: palabras clave por defecto (separadas por coma)
DEFAULT_KEYWORDS=frontend developer,react developer

# Cuántas horas entre scraping automático (0 = desactivado)
SCRAPE_INTERVAL_HOURS=6

# País/región para filtrar resultados (ej: Argentina, Uruguay, Remote)
SEARCH_COUNTRY=Argentina
