# Anthropic API — para análisis de IA
# Obtenela en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Puerto del servidor
PORT=3000

# Firebase Admin SDK — service account
# Firebase Console → Project Settings → Cuentas de servicio → Generar nueva clave privada
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# Scraping: palabras clave por defecto (separadas por coma)
DEFAULT_KEYWORDS=frontend developer,react developer

# Cuántas horas entre scraping automático (0 = desactivado)
# NOTA: el cron multi-usuario todavía no está activo, ver server.js
SCRAPE_INTERVAL_HOURS=0

# País/región para filtrar resultados (ej: Argentina, Uruguay, Remote)
SEARCH_COUNTRY=Argentina
